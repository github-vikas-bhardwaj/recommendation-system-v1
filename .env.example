# Copy to .env.local for local development (gitignored).
# Local uses the TESTING Supabase project — see docs/environments.md

APP_ENV=local

# Supabase — recommendation-system-testing-v1 (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-testing-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-testing-publishable-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-testing-service-role-key

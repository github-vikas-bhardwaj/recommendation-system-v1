{
  "name": "recommendation-system-v",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "typegen": "next typegen",
    "knip": "knip",
    "format:fix": "prettier --write",
    "validate:branch": "sh .husky/validate-branch-name.sh",
    "release": "release-it",
    "release:dry-run": "release-it -VV --dry-run",
    "release:ci": "release-it --ci",
    "release:ci:dry-run": "release-it --ci -VV --dry-run",
    "db:seed": "node --env-file=.env.local scripts/seed-shows.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.107.0",
    "argon2": "0.44.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@release-it/conventional-changelog": "11.0.1",
    "@tailwindcss/postcss": "4",
    "@types/node": "20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "eslint": "9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "knip": "6.14.2",
    "lint-staged": "17.0.6",
    "prettier": "3.8.3",
    "release-it": "20.2.0",
    "tailwindcss": "4",
    "typescript": "5"
  }
}
